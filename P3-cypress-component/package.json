{
  "name": "cypress-component-testing",
  "version": "1.0.0",
  "description": "Cypress 13 E2E and Component test suite",
  "author": "Tanvir Hossain <iamtanvir.cse@gmail.com>",
  "license": "MIT",
  "scripts": {
    "test": "cypress run",
    "test:e2e": "cypress run --spec 'cypress/e2e/**'",
