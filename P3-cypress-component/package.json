    "test:ci": "cypress run --headless --browser chrome",
    "open": "cypress open"
  },
  "devDependencies": {
    "cypress": "^13.6.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "@cypress/react": "^8.0.0",
    "@cypress/webpack-dev-server": "^3.8.0"
  }
}
